---
---

<div class="prose">
  <slot />
</div>

<style>
  .prose {
    max-width: var(--container-prose);
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: 1.7;
    color: var(--color-fg);
  }

  .prose :global(h1),
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    line-height: 1.3;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-weight: 600;
  }

  .prose :global(h1) { font-size: var(--text-4xl); }
  .prose :global(h2) { font-size: var(--text-3xl); }
  .prose :global(h3) { font-size: var(--text-2xl); }
  .prose :global(h4) { font-size: var(--text-xl); }

  .prose :global(p) {
    margin-top: 0;
    margin-bottom: 1.25rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .prose :global(li + li) {
    margin-top: 0.35rem;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    margin-left: 0;
    padding-left: 1.25rem;
    color: var(--color-fg-muted);
    font-style: italic;
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--color-peach);
    padding: 0.1em 0.35em;
    border-radius: 0.25rem;
  }

  .prose :global(pre) {
    background: var(--color-cocoa);
    color: var(--color-cream);
    padding: 1.25rem;
    border-radius: var(--radius-card);
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.5;
    margin-bottom: 1.25rem;
  }

  .prose :global(pre code) {
    background: transparent;
    padding: 0;
  }

  .prose :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-card);
    display: block;
    margin: 1.5rem 0;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-peach);
    margin: 2rem 0;
  }
</style>
