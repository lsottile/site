---
const year = new Date().getFullYear();
---

<footer>
  <p class="footer-text">
    &copy; {year} Luciano Sottile
  </p>
</footer>

<style>
  footer {
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-peach);
  }

  .footer-text {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--color-fg-muted);
    margin: 0;
  }
</style>
