---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import { getMusic } from '../lib/cms/music';

let tracks: Awaited<ReturnType<typeof getMusic>> = [];
try {
  tracks = await getMusic();
} catch (err) {
  console.error('[music] Failed to fetch from Notion:', err);
}

const STATUS_LABEL: Record<string, string> = {
  now:      'Listening now',
  favorite: 'Favorite',
  archive:  'Archive',
};

const KIND_LABEL: Record<string, string> = {
  track:    'Track',
  album:    'Album',
  playlist: 'Playlist',
  artist:   'Artist',
};
---

<BaseLayout
  title="Music"
  description="Music Luciano loves — tracks, albums, playlists."
>
  <div class="music-page">
    <header class="page-header">
      <h1>Music</h1>
      <p class="page-subtitle">Things I've been listening to.</p>
    </header>

    {tracks.length === 0 ? (
      <p class="empty-state">
        Music entries will appear here once connected to Notion.
      </p>
    ) : (
      <ul role="list" class="music-list">
        {tracks.map((entry) => (
          <li class="music-item">
            <div class="music-cover-wrap">
              {entry.coverUrl ? (
                <img
                  src={entry.coverUrl}
                  alt={entry.title}
                  width="64"
                  height="64"
                  class="music-cover"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="music-cover-placeholder" aria-hidden="true">♫</div>
              )}
            </div>
            <div class="music-info">
              <div class="music-title-row">
                {entry.url ? (
                  <a href={entry.url} target="_blank" rel="noopener noreferrer" class="music-title">
                    {entry.title}
                  </a>
                ) : (
                  <span class="music-title">{entry.title}</span>
                )}
                <span class="music-kind">{KIND_LABEL[entry.kind] ?? entry.kind}</span>
              </div>
              <span class="music-artist">{entry.artist}</span>
              {entry.note && <p class="music-note">{entry.note}</p>}
            </div>
            <span class="music-status">{STATUS_LABEL[entry.status] ?? entry.status}</span>
          </li>
        ))}
      </ul>
    )}
  </div>
</BaseLayout>

<style>
  .music-page {
    max-width: var(--container-prose);
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-size: var(--text-4xl);
    font-weight: 600;
    margin: 0 0 0.5rem;
  }

  .page-subtitle {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-fg-muted);
    margin: 0;
  }

  .empty-state {
    font-family: var(--font-sans);
    color: var(--color-fg-muted);
    font-size: var(--text-base);
  }

  .music-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .music-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem;
    border-radius: var(--radius-card);
    background: var(--color-bg-soft);
  }

  .music-cover-wrap {
    flex-shrink: 0;
  }

  .music-cover {
    width: 4rem;
    height: 4rem;
    object-fit: cover;
    border-radius: 0.375rem;
    display: block;
  }

  .music-cover-placeholder {
    width: 4rem;
    height: 4rem;
    border-radius: 0.375rem;
    background: var(--color-peach);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-2xl);
    color: var(--color-fg-muted);
  }

  .music-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .music-title-row {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .music-title {
    font-weight: 600;
    font-size: var(--text-base);
    color: var(--color-fg);
    text-decoration: none;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  a.music-title:hover {
    color: var(--color-accent);
  }

  .music-kind {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--color-fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .music-artist {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
  }

  .music-note {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    font-style: italic;
  }

  .music-status {
    flex-shrink: 0;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    padding: 0.2rem 0.55rem;
    background: var(--color-peach);
    border-radius: 999px;
    color: var(--color-cocoa);
    font-weight: 600;
    white-space: nowrap;
  }
</style>
