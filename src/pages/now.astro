---
import BaseLayout from '../layouts/BaseLayout.astro';
import NowSection from '../components/NowSection.astro';
import { getActiveNow } from '../lib/cms/now';
import type { NowSnapshot } from '../lib/cms/types';

let snapshot: NowSnapshot | null = null;
let error = false;

try {
  snapshot = await getActiveNow();
} catch (err) {
  error = true;
  console.error('[now] Failed to fetch from Notion:', err);
  Astro.response.status = 500;
}
---

<BaseLayout
  title="Now"
  description="What Luciano is up to right now — location, listening, doing."
>
  <div class="now-page">
    <header class="page-header">
      <h1>now</h1>
      <p class="page-subtitle">a snapshot of what i'm up to at this moment</p>
    </header>

    {error && (
      <p class="empty-state">This page is being updated — check back in a moment.</p>
    )}

    {snapshot && <NowSection snapshot={snapshot} />}
  </div>
</BaseLayout>

<style>
  .now-page {
    max-width: var(--container-prose);
  }
</style>
