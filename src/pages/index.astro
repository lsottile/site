---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getBio } from '../lib/cms/bio';

let bio = { name: 'Luciano Sottile', tagline: null as string | null, bodyHtml: null as string | null };
try {
  bio = await getBio();
} catch (err) {
  console.error('[bio] Failed to fetch from Notion:', err);
}
---

<BaseLayout
  title="Bio"
  description={bio.tagline ?? 'Luciano Sottile — developer, nomad, traveling Europe.'}
>
  <article class="bio">
    <header class="page-header">
      <h1>{bio.name}</h1>
      {bio.tagline && <p class="page-subtitle">{bio.tagline}</p>}
    </header>

    {bio.bodyHtml && (
      <div class="bio-body" set:html={bio.bodyHtml} />
    )}

    <div class="bio-links">
      <a href="/now">what i'm doing now &rarr;</a>
    </div>
  </article>
</BaseLayout>

<style>
  .bio {
    max-width: var(--container-prose);
  }

  .bio-body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .bio-body p {
    margin: 0;
    font-size: var(--text-lg);
    line-height: 1.7;
  }

  .bio-links {
    margin-top: 2.5rem;
    font-size: var(--text-sm);
    font-weight: 600;
  }

  .bio-links a {
    text-decoration: none;
    color: var(--color-accent);
  }

  .bio-links a:hover {
    color: var(--color-accent-hi);
  }
</style>
