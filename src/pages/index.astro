---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Bio"
  description="Luciano Sottile — developer, nomad, traveling Europe with his girlfriend."
>
  <article class="bio">
    <header class="bio-header">
      <h1 class="bio-name">Luciano Sottile</h1>
      <p class="bio-tagline">Developer &amp; nomad. Traveling Europe.</p>
    </header>

    <div class="bio-body">
      <p>
        I'm a developer based wherever my suitcase lands. Right now I'm somewhere in Europe
        with my girlfriend, figuring out cities one coffee at a time.
      </p>
      <p>
        I care a lot about good design, clean code, and things that are built to last.
        When I'm not at a laptop I'm usually watching football, listening to Oasis,
        or hunting for a decent vintage jacket.
      </p>
      <p>
        This site is my small corner of the internet — a place to share what I'm up to,
        photos from the road, music I love, and the occasional long-form thought.
      </p>
    </div>

    <div class="bio-links">
      <a href="/now">What I'm doing now &rarr;</a>
    </div>
  </article>
</BaseLayout>

<style>
  .bio {
    max-width: var(--container-prose);
  }

  .bio-header {
    margin-bottom: 2rem;
  }

  .bio-name {
    font-size: var(--text-4xl);
    font-weight: 600;
    line-height: 1.1;
    margin: 0 0 0.5rem;
  }

  .bio-tagline {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--color-fg-muted);
    margin: 0;
  }

  .bio-body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .bio-body p {
    margin: 0;
    font-size: var(--text-lg);
    line-height: 1.7;
  }

  .bio-links {
    margin-top: 2.5rem;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
  }

  .bio-links a {
    text-decoration: none;
    color: var(--color-accent);
  }

  .bio-links a:hover {
    color: var(--color-accent-hi);
  }
</style>
