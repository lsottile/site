---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getBio } from '../lib/cms/bio';

let bio = { name: 'Luciano Sottile', tagline: null as string | null, body: null as string | null };
try {
  bio = await getBio();
} catch (err) {
  console.error('[bio] Failed to fetch from Notion:', err);
}
---

<BaseLayout
  title="Bio"
  description={bio.tagline ?? 'Luciano Sottile — developer, nomad, traveling Europe.'}
>
  <article class="bio">
    <header class="bio-header">
      <h1 class="bio-name">{bio.name}</h1>
      {bio.tagline && <p class="bio-tagline">{bio.tagline}</p>}
    </header>

    {bio.body && (
      <div class="bio-body">
        <p>{bio.body}</p>
      </div>
    )}

    <div class="bio-links">
      <a href="/now">What I'm doing now &rarr;</a>
    </div>
  </article>
</BaseLayout>

<style>
  .bio {
    max-width: var(--container-prose);
  }

  .bio-header {
    margin-bottom: 2rem;
  }

  .bio-name {
    font-size: var(--text-4xl);
    font-weight: 600;
    line-height: 1.1;
    margin: 0 0 0.5rem;
  }

  .bio-tagline {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--color-fg-muted);
    margin: 0;
  }

  .bio-body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .bio-body p {
    margin: 0;
    font-size: var(--text-lg);
    line-height: 1.7;
  }

  .bio-links {
    margin-top: 2.5rem;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
  }

  .bio-links a {
    text-decoration: none;
    color: var(--color-accent);
  }

  .bio-links a:hover {
    color: var(--color-accent-hi);
  }
</style>
