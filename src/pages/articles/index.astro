---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { listArticles } from '../../lib/cms/articles';

let articles: Awaited<ReturnType<typeof listArticles>> = [];
try {
  articles = await listArticles();
} catch (err) {
  console.error('[articles] Failed to fetch from Notion:', err);
}
---

<BaseLayout
  title="Articles"
  description="Long-form writing by Luciano Sottile."
>
  <div class="articles-page">
    <header class="page-header">
      <h1>Articles</h1>
      <p class="page-subtitle">Long-form thoughts, occasionally.</p>
    </header>

    {articles.length === 0 ? (
      <p class="empty-state">No published articles yet — check back soon.</p>
    ) : (
      <ul role="list" class="article-list">
        {articles.map((article) => (
          <li>
            <ArticleCard article={article} />
          </li>
        ))}
      </ul>
    )}
  </div>
</BaseLayout>

<style>
  .articles-page {
    max-width: var(--container-prose);
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-size: var(--text-4xl);
    font-weight: 600;
    margin: 0 0 0.5rem;
  }

  .page-subtitle {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-fg-muted);
    margin: 0;
  }

  .empty-state {
    font-family: var(--font-sans);
    color: var(--color-fg-muted);
    font-size: var(--text-base);
  }

  .article-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>
