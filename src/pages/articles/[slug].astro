---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Prose from '../../components/Prose.astro';
import { getArticleBySlug } from '../../lib/cms/articles';
import { marked } from 'marked';

const { slug } = Astro.params;

if (!slug) return Astro.redirect('/articles', 302);

const article = await getArticleBySlug(slug);

if (!article) {
  return new Response(null, { status: 404 });
}

const htmlBody = marked.parse(article.markdown);

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString('en-GB', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout
  title={article.title}
  description={article.excerpt}
  ogImage={article.coverUrl ?? undefined}
>
  <article class="article-detail">
    {article.coverUrl && (
      <img
        src={article.coverUrl}
        alt={article.coverAlt ?? article.title}
        class="article-hero"
        loading="eager"
        decoding="async"
      />
    )}

    <header class="article-header">
      <h1>{article.title}</h1>
      <p class="article-meta">
        <time datetime={article.publishedAt}>{formatDate(article.publishedAt)}</time>
        {article.readingTime && <span> · {article.readingTime} min read</span>}
      </p>
      {article.tags.length > 0 && (
        <ul role="list" class="article-tags">
          {article.tags.map((tag) => <li class="article-tag">{tag}</li>)}
        </ul>
      )}
    </header>

    <Prose>
      <Fragment set:html={htmlBody} />
    </Prose>
  </article>
</BaseLayout>

<style>
  .article-detail {
    max-width: var(--container-prose);
  }

  .article-hero {
    width: 100%;
    height: 20rem;
    object-fit: cover;
    border-radius: var(--radius-card);
    display: block;
    margin-bottom: 2rem;
  }

  .article-header {
    margin-bottom: 2.5rem;
  }

  .article-header h1 {
    font-size: var(--text-4xl);
    font-weight: 600;
    line-height: 1.2;
    margin: 0 0 0.75rem;
  }

  .article-meta {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    margin: 0 0 0.75rem;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .article-tag {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    padding: 0.15rem 0.5rem;
    background: var(--color-peach);
    border-radius: 999px;
    color: var(--color-cocoa);
  }
</style>
