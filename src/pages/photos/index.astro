---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhotoCard from '../../components/PhotoCard.astro';
import { getPhotos } from '../../lib/cms/photos';

let photos: Awaited<ReturnType<typeof getPhotos>> = [];
try {
  photos = await getPhotos();
} catch (err) {
  console.error('[photos] Failed to fetch from Notion:', err);
}
---

<BaseLayout
  title="Photos"
  description="Photos from the road — travel, street, mountains, cities."
>
  <div class="photos-page">
    <header class="page-header">
      <h1>photos</h1>
      <p class="page-subtitle">from the road</p>
    </header>

    {photos.length === 0 ? (
      <p class="empty-state">no photos yet — check back soon</p>
    ) : (
      <div class="photo-grid">
        {photos.map((photo, i) => (
          <PhotoCard photo={photo} loading={i === 0 ? 'eager' : 'lazy'} />
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .photos-page {
    width: 100%;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 480px) {
    .photo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 700px) {
    .photo-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
